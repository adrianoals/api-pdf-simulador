{
  "name": "unifisa-api-pdf",
  "version": "1.0.0",
  "description": "API para geração de PDFs de propostas Unifisa",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon src/index.ts",
    "build": "tsc",
    "build:css": "tailwindcss -i ./src/styles/input.css -o ./public/styles.css --watch",
    "build:css:prod": "tailwindcss -i ./src/styles/input.css -o ./public/styles.css --minify",
    "start": "node dist/index.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
